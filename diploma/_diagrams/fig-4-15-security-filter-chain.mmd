%% Fig 4.15 — Security filter chain
%% Source: author, derived from security/* + config/SecurityConfig (ARCHITECTURE.md §5)
flowchart TD
    req["Incoming request"]
    pub{"Public path?<br/>/api/auth/login · /api/health<br/>/swagger-ui/** · /v3/api-docs/**"}
    filter["JwtAuthenticationFilter<br/>(OncePerRequestFilter)"]
    tok{"Bearer token OR<br/>em_token cookie present?"}
    valid{"JwtTokenProvider.validate()<br/>HS256, not expired"}
    uds["CustomUserDetailsService<br/>load UserDetails"]
    ctx["SecurityContextHolder<br/>set Authentication"]
    method{"@PreAuthorize role check<br/>(ADMIN > TEACHER > STUDENT)"}
    svc["Service-layer data scoping<br/>(teacher -> own groups, student -> self)"]
    ok["Controller handles request"]
    e401["401 Unauthorized"]
    e403["403 Forbidden"]

    req --> pub
    pub -->|yes| ok
    pub -->|no| filter --> tok
    tok -->|no| e401
    tok -->|yes| valid
    valid -->|invalid / expired| e401
    valid -->|valid| uds --> ctx --> method
    method -->|deny| e403
    method -->|allow| svc --> ok
