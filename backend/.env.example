# Copy to .env (which is gitignored) before running `docker compose up`.

# Database
POSTGRES_DB=edumetric
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=prod
LIQUIBASE_CONTEXTS=default

# Required — 32+ byte HMAC key for JWT signing. Generate with:
#   openssl rand -base64 48
JWT_SECRET=

# Frontend origin allowed by CORS (comma-separated list permitted).
CORS_ORIGIN=http://localhost:3000
